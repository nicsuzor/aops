{
  "claude": {
    "mcpServers": {
      "pkb": {
        "command": "bash",
        "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run-mcp.sh"],
        "env": {
          "PKB_MCP_URL": "${PKB_MCP_URL}"
        }
      }
    }
  },
  "gemini": {
    "mcpServers": {
      "pkb": {
        "command": "bash",
        "args": ["${extensionPath}/scripts/run-mcp.sh"],
        "env": {
          "PKB_MCP_URL": "${PKB_MCP_URL}"
        }
      }
    }
  }
}
